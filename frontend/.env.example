# Local dev points at the local backend (Vite proxies /api and /uploads).
# In production (Vercel), set VITE_API_URL in the FRONTEND project's
# Environment Variables to your deployed backend's /api URL, e.g.
#   VITE_API_URL=https://riwaya-api.vercel.app/api
# VITE_* vars are baked in at build time, so changing it requires a redeploy.
VITE_API_URL=http://localhost:5000/api
VITE_BRAND_NAME=RIWAYA
VITE_CURRENCY=PKR
