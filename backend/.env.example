# ===== Server =====
# PORT is for local dev only — Vercel ignores it and manages the port itself.
PORT=5000
NODE_ENV=development
# CORS allow-list / cookie origin. In production set this to the EXACT deployed
# frontend URL (no trailing slash), e.g. https://riwaya.vercel.app
CLIENT_URL=http://localhost:5173

# ===== Database =====
# Local dev: mongodb://127.0.0.1:27017/riwaya
# Production (Vercel): a MongoDB Atlas connection string (mongodb+srv://...)
MONGO_URI=mongodb://127.0.0.1:27017/riwaya

# ===== JWT =====
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string_min_32_chars
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# ===== Cloudinary (images) — REQUIRED (uploads are stored on Cloudinary) =====
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===== Seed: first Super Admin =====
SUPER_ADMIN_NAME=RIWAYA Super Admin
SUPER_ADMIN_EMAIL=superadmin@riwaya.com
SUPER_ADMIN_PASSWORD=Super@1234
